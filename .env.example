# =============================================================
# VERUM COMPOUND ENGINE — Environment Variables
# =============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Verum Compound Engine

# Blockchain — Solana
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta

# Token Addresses (update with real addresses)
NEXT_PUBLIC_BODE_ADDRESS=YOUR_BODE_TOKEN_ADDRESS
NEXT_PUBLIC_ESCOTEIRO_ADDRESS=YOUR_ESCOTEIRO_TOKEN_ADDRESS
NEXT_PUBLIC_BRUTOS_ADDRESS=YOUR_BRUTOS_TOKEN_ADDRESS

# DexScreener API (no key needed for public endpoints)
NEXT_PUBLIC_DEXSCREENER_BASE=https://api.dexscreener.com/latest/dex

# Birdeye API (optional, for enhanced data)
BIRDEYE_API_KEY=YOUR_BIRDEYE_API_KEY

# Jupiter API
NEXT_PUBLIC_JUPITER_API=https://quote-api.jup.ag/v6

# Database (if using Prisma/PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/verum_compound

# Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
